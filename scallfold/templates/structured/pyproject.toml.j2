[tool.poetry]
name = "{{ project_name }}"
version = "{{ version }}"
description = "{{ description }}"
authors = ["Generated by fast-forge"]

# This tells Poetry where to find the package's source code
packages = [{include = "{{ project_name }}", from = "src"}]

[tool.poetry.dependencies]
python = "^3.10"
fastapi = "^0.115.0"
uvicorn = "^0.34.0"
pydantic = "^2.6.2"
pydantic-settings = "^2.2.0"
{% if use_db or use_orm %}
sqlalchemy = "^2.0.0"
{% endif %}

[tool.poetry.dev-dependencies]
pytest = "^7.3.0"
